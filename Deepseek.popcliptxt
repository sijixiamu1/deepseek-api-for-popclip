// #popclip extension for DeepSeek
// name: DeepSeek 问答
// icon: symbol:bubble.medium
// language: javascript
// module: true
// entitlements: [network]
// options:
//   - { identifier: apikey, label: API Key, type: string }
//   - { identifier: prompt, label: 提示词, type: string }

const axios = require("axios");

const deepseek = axios.create({
  baseURL: "https://api.deepseek.com/",
});

const MODEL = "deepseek-chat";

// 核心调用 AI
async function callAI(input, options, promptText) {
  deepseek.defaults.headers.common.Authorization = `Bearer ${options.apikey}`;
  const content = `${promptText}\n\n内容：${input.text.trim()}`;

  const { data } = await deepseek.post("chat/completions", {
    model: MODEL,
    temperature: 0.7,
    messages: [{ role: "user", content }]
  });

  return data.choices[0].message.content.trim();
}

// 提问功能
async function ask(input, options) {
  try {
    const response = await callAI(input, options, options.prompt);
    //popclip.pasteText(response);
    popclip.showText(response);
    return response;
  } catch (error) {
    popclip.showText("出错：" + error.message);
    throw error;
  }
}

// 只导出一个按钮：提问
exports.actions = [
  {
    title: "💬",
    after: "preview-result",
    code: ask,
    icon: "symbol:bubble.medium"
  }
];